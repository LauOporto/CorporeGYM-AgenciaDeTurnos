{
  "info": {
    "name": "CORPORE GYM API",
    "_postman_id": "corpore-gym-api-v1",
    "description": "Colección de requests para probar la API REST de CORPORE GYM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "claseId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"email\": \"juan@test.com\",\n  \"password\": \"MiPassword123!\",\n  \"telefono\": \"+54 11 1234-5678\"\n}"
            }
          }
        },
        {
          "name": "Login usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  pm.collectionVariables.set('userId', json.data.usuario.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"MiPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data.token) {",
                  "  pm.collectionVariables.set('adminToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@corporegym.com\",\n  \"password\": \"Admin123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 Usuarios",
      "item": [
        {
          "name": "Ver mi perfil",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Editar mi perfil",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan P. Editado\",\n  \"telefono\": \"+54 11 9999-0000\"\n}"
            }
          }
        },
        {
          "name": "Ver mis clases",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId}}/classes"
          }
        },
        {
          "name": "Eliminar mi cuenta",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "🏋️ Clases",
      "item": [
        {
          "name": "Listar todas las clases",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/classes"
          }
        },
        {
          "name": "Ver detalle de clase",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/classes/{{claseId}}"
          }
        },
        {
          "name": "[Admin] Crear clase",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data.id) {",
                  "  pm.collectionVariables.set('claseId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/classes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Pilates Matutino\",\n  \"descripcion\": \"Clase introductoria de pilates\",\n  \"fecha\": \"2026-04-01\",\n  \"hora_inicio\": \"09:00\",\n  \"hora_fin\": \"10:00\",\n  \"cupo_maximo\": 10,\n  \"profesor_id\": 1\n}"
            }
          }
        },
        {
          "name": "[Admin] Editar clase",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/classes/{{claseId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cupo_maximo\": 15,\n  \"descripcion\": \"Clase actualizada\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📅 Inscripciones",
      "item": [
        {
          "name": "Inscribirse a una clase",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/classes/{{claseId}}/enroll"
          }
        },
        {
          "name": "Cancelar inscripción",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/classes/{{claseId}}/enroll"
          }
        }
      ]
    },
    {
      "name": "✅ Asistencia (Admin)",
      "item": [
        {
          "name": "Ver asistencia de una clase",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/classes/{{claseId}}/attendance"
          }
        },
        {
          "name": "Registrar asistencia",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/classes/{{claseId}}/attendance",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asistencias\": [\n    { \"usuario_id\": 2, \"presente\": true },\n    { \"usuario_id\": 3, \"presente\": false }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🛠️ Administración (Admin)",
      "item": [
        {
          "name": "Ver alumnos de una clase",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/classes/{{claseId}}/students"
          }
        },
        {
          "name": "Mover alumno a otra clase",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/classes/{{claseId}}/move-user",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": 2,\n  \"nueva_clase_id\": 3\n}"
            }
          }
        },
        {
          "name": "Remover alumno de clase",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/classes/{{claseId}}/remove-user",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": 2\n}"
            }
          }
        }
      ]
    }
  ]
}
